# ============================================================
# Idobetz AI Bot - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32

# Database (PostgreSQL)
POSTGRES_USER=idobetz
POSTGRES_PASSWORD=your-strong-db-password
POSTGRES_DB=idobetz_ai
DATABASE_URL=postgresql://idobetz:${POSTGRES_PASSWORD}@localhost:5432/idobetz_ai

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=  # Leave empty for dev, set for production

# ── AI Providers ──────────────────────────────────────────────
# OpenAI GPT-4
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AI Routing: openai | claude | ollama | consensus
AI_PROVIDER=openai
AI_FALLBACK_PROVIDER=claude

# Ollama (Local LLM - optional for private mode)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── WhatsApp Business API ─────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=EAAxxxxx...
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_API_VERSION=v20.0

# ── Meta Messenger ────────────────────────────────────────────
MESSENGER_PAGE_ACCESS_TOKEN=EAAxxxxx...
MESSENGER_APP_SECRET=your-app-secret
MESSENGER_WEBHOOK_VERIFY_TOKEN=your-messenger-verify-token

# ── Instagram ─────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-instagram-verify-token

# ── Website Integration ───────────────────────────────────────
# Your website API - products and orders will be synced from here
WEBSITE_API_URL=https://idobetz.co.il/wp-json/wc/v3
WEBSITE_API_KEY=ck_...
PRODUCT_SYNC_INTERVAL_MINUTES=60
ORDER_SYNC_INTERVAL_MINUTES=5

# ── AWS S3 (for media storage) ────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=idobetz-media
AWS_REGION=us-east-1

# ── Admin Dashboard ───────────────────────────────────────────
ADMIN_EMAIL=admin@idobetz.co.il
ADMIN_PASSWORD=change-me-strong-password

# ── Security ──────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=*

# ── Loyalty Program ───────────────────────────────────────────
LOYALTY_POINTS_PER_PURCHASE=10
LOYALTY_POINTS_PER_REFERRAL=50

# ── Monitoring (optional) ─────────────────────────────────────
SENTRY_DSN=
